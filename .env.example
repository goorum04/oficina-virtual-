# Postgres connection string used by Prisma (e.g. a Supabase project)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# URL of the office-ws WebSocket service (mini-services/office-ws), used for
# live agent/task/activity updates. Same value is read on client and server.
# Optional: the app still works without it (falls back to refetching on
# "Simular"), it just won't push live updates.
NEXT_PUBLIC_WS_URL=http://localhost:3004
