# Postgres connection string used by Prisma (e.g. a Supabase project)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Anthropic API key, used by /api/agents/[id]/chat to power real agent
# replies. Without it, agents reply with a placeholder message instead.
ANTHROPIC_API_KEY=sk-ant-...

# GitHub App used by /api/github/* so agents can read/write files and open
# PRs on repos you explicitly grant access to. Create the app at
# github.com/settings/apps/new (Contents: R/W, Pull requests: R/W, Metadata:
# read), set its callback URL to <your-app-url>/api/github/callback.
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_CLIENT_ID=Iv1....
GITHUB_CLIENT_SECRET=...

# URL of the office-ws WebSocket service (mini-services/office-ws), used for
# live agent/task/activity updates. Same value is read on client and server.
# Optional: the app still works without it (falls back to refetching on
# "Simular"), it just won't push live updates.
NEXT_PUBLIC_WS_URL=http://localhost:3004
